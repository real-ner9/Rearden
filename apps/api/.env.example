# API Configuration
PORT=3001
NODE_ENV=development

# Security - REQUIRED: No fallback values for production security
JWT_SECRET=your-secure-jwt-secret-here-change-this

# Database - REQUIRED
DATABASE_URL=postgresql://rearden:rearden@localhost:5434/rearden?schema=public

# S3/MinIO Configuration - REQUIRED: No fallback values for security
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=rearden-media
S3_PUBLIC_URL=http://localhost:9002/rearden-media
S3_ACCESS_KEY=rearden
S3_SECRET_KEY=reardenpass

# CORS - Optional: Defaults to localhost:3000 if not set
CORS_ORIGIN=http://localhost:3000
